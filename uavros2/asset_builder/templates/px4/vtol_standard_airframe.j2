#!/bin/sh
#
# @name {{ short_name }}
#
# @type Standard VTOL
#

. ${R}etc/init.d/rc.vtol_defaults

PX4_SIMULATOR=${PX4_SIMULATOR:=gz}
PX4_GZ_WORLD=${PX4_GZ_WORLD:=default}
PX4_SIM_MODEL=${PX4_SIM_MODEL:={{ uav.name }}}

param set-default SIM_GZ_EN 1
param set-default UXRCE_DDS_DOM_ID 0

param set-default EKF2_HGT_REF 0
param set-default SENS_EN_GPSSIM 1
param set-default SENS_EN_BAROSIM 1
param set-default SENS_EN_MAGSIM 1

# Standard VTOL (multirotor lift + fixed-wing cruise)
param set-default CA_AIRFRAME 2
param set-default CA_ROTOR_COUNT {{ rotor_count }}
{% for r in rotors %}
param set-default CA_ROTOR{{ loop.index0 }}_PX {{ "%.2f"|format(r.pose[0]) }}
param set-default CA_ROTOR{{ loop.index0 }}_PY {{ "%.2f"|format(r.pose[1]) }}
param set-default CA_ROTOR{{ loop.index0 }}_KM {{ "%+.2f"|format(r.km_signed) }}
{% endfor %}

# Control surfaces
param set-default CA_SV_CS_COUNT {{ control_surface_count }}
{% for cs in control_surfaces %}
param set-default CA_SV_CS{{ loop.index0 }}_TYPE {{ cs.type_id }}
param set-default CA_SV_CS{{ loop.index0 }}_TRQ_R {{ "%.2f"|format(cs.trq_roll) }}
param set-default CA_SV_CS{{ loop.index0 }}_TRQ_P {{ "%.2f"|format(cs.trq_pitch) }}
param set-default CA_SV_CS{{ loop.index0 }}_TRQ_Y {{ "%.2f"|format(cs.trq_yaw) }}
{% endfor %}

{% for i in range(rotor_count) %}
param set-default SIM_GZ_EC_FUNC{{ i + 1 }} {{ 101 + i }}
{% endfor %}
{% for i in range(rotor_count) %}
param set-default SIM_GZ_EC_MIN{{ i + 1 }} 150
{% endfor %}
{% for i in range(rotor_count) %}
param set-default SIM_GZ_EC_MAX{{ i + 1 }} 1000
{% endfor %}
{% for i in range(control_surface_count) %}
param set-default SIM_GZ_SV_FUNC{{ i + 1 }} {{ 201 + i }}
{% endfor %}

# VTOL transition
{% if transition.forward_airspeed_mps is not none %}
param set-default VT_ARSP_TRANS {{ "%.1f"|format(transition.forward_airspeed_mps) }}
{% endif %}
param set-default VT_PSHER_RMP 3.0
param set-default VT_F_TRANS_DUR 6.0
param set-default VT_B_TRANS_DUR 4.0

param set-default MPC_THR_HOVER {{ "%.2f"|format(hover_thrust) }}
{% for key, val in extra_params|dictsort %}
param set-default {{ key }} {{ val }}
{% endfor %}
