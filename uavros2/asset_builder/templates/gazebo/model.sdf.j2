{# Generated by uavros2-asset build. Do not hand-edit. -#}
<?xml version="1.0" encoding="UTF-8"?>
<sdf version='1.9'>
  <model name='{{ uav.name }}'>
    <!-- Chassis: {{ chassis.name }} ({{ chassis.type }}) -->
    <include merge='true'>
      <uri>model://{{ chassis.name }}</uri>
    </include>
{% for sensor in sensors %}
{% if sensor.gz_model %}
    <!-- Sensor: {{ sensor.name }} (type={{ sensor.ref }}) -->
    <include merge='true'>
      <name>{{ sensor.name }}</name>
      <uri>model://{{ sensor.gz_model }}</uri>
      <pose relative_to="{{ sensor.mount }}" degrees="true">{{ sensor.pose_sdf }}</pose>
    </include>
{% if sensor.body_link %}
    <joint name="{{ sensor.name }}_joint" type="fixed">
      <parent>{{ sensor.mount }}</parent>
      <child>{{ sensor.name }}::{{ sensor.body_link }}</child>
      <pose relative_to="{{ sensor.mount }}" degrees="true">{{ sensor.pose_sdf }}</pose>
    </joint>
{% endif %}
{% else %}
    <!-- Sensor: {{ sensor.name }} (type={{ sensor.ref }}, embedded in chassis SDF; documented only) -->
{% endif %}
{% endfor %}
{% if arm %}
    <!-- Arm: {{ arm.ref }} mounted on {{ arm.mount }} -->
    <include merge='true'>
      <uri>model://arm_{{ arm.ref }}</uri>
      <pose relative_to="{{ arm.mount }}" degrees="true">{{ arm.pose_sdf }}</pose>
    </include>
    <plugin filename='libgz_ros2_control-system.so'
            name='gz_ros2_control::GazeboSimROS2ControlPlugin'>
      <parameters>@UAVROS2_PKG_SHARE@/arms/{{ arm.ref }}/config/controllers.yaml</parameters>
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <controller_manager_node_name>controller_manager</controller_manager_node_name>
      <ros>
        <namespace>@UAVROS2_NAMESPACE@</namespace>
      </ros>
    </plugin>
{% endif %}
{% for raw in extra_xml %}
{{ raw }}
{% endfor %}
  </model>
</sdf>
