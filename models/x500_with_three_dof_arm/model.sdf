<?xml version="1.0" encoding="UTF-8"?>
<!--
  Composed model: PX4 x500 quadcopter + custom 3-DOF arm.
  Dimensions mirror arms/three_dof/urdf/three_dof.urdf.xacro.
  Total arm drop below base_link is 0.05 mount + 3 x 0.04 segment +
  0.015 ee sphere = 0.185 m, which keeps the EE above the x500
  landing gear feet at z = -0.2195 m.
  Joint commands are routed through gz_ros2_control so ros2_control
  controllers (joint_state_broadcaster, joint_trajectory_controller)
  and MoveIt all see the standard hardware interface.
-->
<sdf version='1.9'>
  <model name='x500_with_three_dof_arm'>

    <!-- Bring in the bare quadrotor (base_link + 4 rotors + IMU) -->
    <include merge='true'>
      <uri>model://x500</uri>
    </include>

    <!-- ===== Arm: shoulder ===== -->
    <link name='shoulder_link'>
      <pose relative_to='base_link'>0 0 -0.05 3.14159 0 0</pose>
      <inertial>
        <mass>0.04</mass>
        <pose>0 0 0.02 0 0 0</pose>
        <inertia>
          <ixx>6.00e-6</ixx><iyy>6.00e-6</iyy><izz>1.28e-6</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='shoulder_visual'>
        <pose>0 0 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.008</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.8 0.3 0.3 1</ambient><diffuse>0.8 0.3 0.3 1</diffuse></material>
      </visual>
      <collision name='shoulder_collision'>
        <pose>0 0 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.008</radius><length>0.04</length></cylinder></geometry>
      </collision>
    </link>
    <joint name='j_shoulder' type='revolute'>
      <parent>base_link</parent>
      <child>shoulder_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-3.14159</lower><upper>3.14159</upper>
               <effort>2.0</effort><velocity>3.0</velocity></limit>
        <dynamics><damping>0.05</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>

    <!-- ===== Arm: upper ===== -->
    <link name='upper_link'>
      <pose relative_to='shoulder_link'>0 0 0.04 0 0 0</pose>
      <inertial>
        <mass>0.035</mass>
        <pose>0 0 0.02 0 0 0</pose>
        <inertia>
          <ixx>5.25e-6</ixx><iyy>5.25e-6</iyy><izz>1.12e-6</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='upper_visual'>
        <pose>0 0 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.008</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.3 0.8 0.3 1</ambient><diffuse>0.3 0.8 0.3 1</diffuse></material>
      </visual>
      <collision name='upper_collision'>
        <pose>0 0 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.008</radius><length>0.04</length></cylinder></geometry>
      </collision>
    </link>
    <joint name='j_elbow' type='revolute'>
      <parent>shoulder_link</parent>
      <child>upper_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-3.14159</lower><upper>3.14159</upper>
               <effort>1.5</effort><velocity>3.0</velocity></limit>
        <dynamics><damping>0.05</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>

    <!-- ===== Arm: forearm ===== -->
    <link name='forearm_link'>
      <pose relative_to='upper_link'>0 0 0.04 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <pose>0 0 0.02 0 0 0</pose>
        <inertia>
          <ixx>4.50e-6</ixx><iyy>4.50e-6</iyy><izz>9.60e-7</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='forearm_visual'>
        <pose>0 0 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.008</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.3 0.3 0.8 1</ambient><diffuse>0.3 0.3 0.8 1</diffuse></material>
      </visual>
      <collision name='forearm_collision'>
        <pose>0 0 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.008</radius><length>0.04</length></cylinder></geometry>
      </collision>
    </link>
    <joint name='j_wrist' type='revolute'>
      <parent>upper_link</parent>
      <child>forearm_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-3.14159</lower><upper>3.14159</upper>
               <effort>1.0</effort><velocity>3.0</velocity></limit>
        <dynamics><damping>0.05</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>

    <!-- ===== End effector (fixed) ===== -->
    <link name='ee_link'>
      <pose relative_to='forearm_link'>0 0 0.05 0 0 0</pose>
      <inertial>
        <mass>0.015</mass>
        <inertia>
          <ixx>5e-6</ixx><iyy>5e-6</iyy><izz>5e-6</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='ee_visual'>
        <geometry><sphere><radius>0.012</radius></sphere></geometry>
        <material><ambient>1 1 0 1</ambient><diffuse>1 1 0 1</diffuse></material>
      </visual>
      <collision name='ee_collision'>
        <geometry><sphere><radius>0.012</radius></sphere></geometry>
      </collision>
    </link>
    <joint name='j_ee' type='fixed'>
      <parent>forearm_link</parent>
      <child>ee_link</child>
    </joint>

    <!--
      Two markers are substituted at launch time by
      simulators/gazebo.launch.py (gz_ros2_control does not expand
      $(find ...) or package:// URIs in <parameters>, and its
      controller_manager node defaults to the global root):
        @UAVROS2_PKG_SHARE@  - install share dir
        @UAVROS2_NAMESPACE@  - the drone's ROS namespace, so
                                  controller_manager, robot_description
                                  subscription, and spawners all agree
                                  on /<ns>/controller_manager,
                                  /<ns>/robot_description.
    -->
    <plugin filename='libgz_ros2_control-system.so'
            name='gz_ros2_control::GazeboSimROS2ControlPlugin'>
      <parameters>@UAVROS2_PKG_SHARE@/arms/three_dof/config/controllers.yaml</parameters>
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <controller_manager_node_name>controller_manager</controller_manager_node_name>
      <ros>
        <namespace>@UAVROS2_NAMESPACE@</namespace>
      </ros>
    </plugin>

  </model>
</sdf>
