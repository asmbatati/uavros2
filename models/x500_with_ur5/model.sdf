<?xml version="1.0" encoding="UTF-8"?>
<!--
  Composed model: PX4 x500 quadcopter + scaffold ur5 arm.
  This is a cylinder-chain scaffold matching arms/ur5/config/
  controllers.yaml joint names, NOT the real ur5 kinematics. It
  lets `arm:=ur5` spawn and respond to ros2_control commands today;
  real meshes / inertias can be back-filled by overwriting this SDF
  later with one generated from the upstream description package.
  Joint commands routed through gz_ros2_control (see plugin below).
-->
<sdf version='1.9'>
  <model name='x500_with_ur5'>

    <include merge='true'>
      <uri>model://x500</uri>
    </include>

    <link name='ur5_link1'>
      <pose relative_to='base_link'>0 0 -0.05 3.14159 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <pose>0 0 0.0600 0 0 0</pose>
        <inertia>
          <ixx>5.124000e-04</ixx><iyy>5.124000e-04</iyy><izz>6.480000e-05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='ur5_link1_visual'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
      <collision name='ur5_link1_collision'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
      </collision>
    </link>
    <joint name='shoulder_pan_joint' type='revolute'>
      <parent>base_link</parent>
      <child>ur5_link1</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-3.14159</lower><upper>3.14159</upper>
               <effort>2.0</effort><velocity>3.0</velocity></limit>
        <dynamics><damping>0.05</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>
    <link name='ur5_link2'>
      <pose relative_to='ur5_link1'>0 0 0.1200 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <pose>0 0 0.0600 0 0 0</pose>
        <inertia>
          <ixx>5.124000e-04</ixx><iyy>5.124000e-04</iyy><izz>6.480000e-05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='ur5_link2_visual'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
        <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
      </visual>
      <collision name='ur5_link2_collision'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
      </collision>
    </link>
    <joint name='shoulder_lift_joint' type='revolute'>
      <parent>ur5_link1</parent>
      <child>ur5_link2</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-3.14159</lower><upper>3.14159</upper>
               <effort>2.0</effort><velocity>3.0</velocity></limit>
        <dynamics><damping>0.05</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>
    <link name='ur5_link3'>
      <pose relative_to='ur5_link2'>0 0 0.1200 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <pose>0 0 0.0600 0 0 0</pose>
        <inertia>
          <ixx>5.124000e-04</ixx><iyy>5.124000e-04</iyy><izz>6.480000e-05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='ur5_link3_visual'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
      <collision name='ur5_link3_collision'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
      </collision>
    </link>
    <joint name='elbow_joint' type='revolute'>
      <parent>ur5_link2</parent>
      <child>ur5_link3</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-3.14159</lower><upper>3.14159</upper>
               <effort>2.0</effort><velocity>3.0</velocity></limit>
        <dynamics><damping>0.05</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>
    <link name='ur5_link4'>
      <pose relative_to='ur5_link3'>0 0 0.1200 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <pose>0 0 0.0600 0 0 0</pose>
        <inertia>
          <ixx>5.124000e-04</ixx><iyy>5.124000e-04</iyy><izz>6.480000e-05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='ur5_link4_visual'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
        <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
      </visual>
      <collision name='ur5_link4_collision'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
      </collision>
    </link>
    <joint name='wrist_1_joint' type='revolute'>
      <parent>ur5_link3</parent>
      <child>ur5_link4</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-3.14159</lower><upper>3.14159</upper>
               <effort>2.0</effort><velocity>3.0</velocity></limit>
        <dynamics><damping>0.05</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>
    <link name='ur5_link5'>
      <pose relative_to='ur5_link4'>0 0 0.1200 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <pose>0 0 0.0600 0 0 0</pose>
        <inertia>
          <ixx>5.124000e-04</ixx><iyy>5.124000e-04</iyy><izz>6.480000e-05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='ur5_link5_visual'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
      <collision name='ur5_link5_collision'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
      </collision>
    </link>
    <joint name='wrist_2_joint' type='revolute'>
      <parent>ur5_link4</parent>
      <child>ur5_link5</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-3.14159</lower><upper>3.14159</upper>
               <effort>2.0</effort><velocity>3.0</velocity></limit>
        <dynamics><damping>0.05</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>
    <link name='ur5_link6'>
      <pose relative_to='ur5_link5'>0 0 0.1200 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <pose>0 0 0.0600 0 0 0</pose>
        <inertia>
          <ixx>5.124000e-04</ixx><iyy>5.124000e-04</iyy><izz>6.480000e-05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='ur5_link6_visual'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
        <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
      </visual>
      <collision name='ur5_link6_collision'>
        <pose>0 0 0.0600 0 0 0</pose>
        <geometry><cylinder><radius>0.018</radius><length>0.12</length></cylinder></geometry>
      </collision>
    </link>
    <joint name='wrist_3_joint' type='revolute'>
      <parent>ur5_link5</parent>
      <child>ur5_link6</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-3.14159</lower><upper>3.14159</upper>
               <effort>2.0</effort><velocity>3.0</velocity></limit>
        <dynamics><damping>0.05</damping><friction>0.01</friction></dynamics>
      </axis>
    </joint>
    <link name='tool0'>
      <pose relative_to='ur5_link6'>0 0 0.1300 0 0 0</pose>
      <inertial>
        <mass>0.02</mass>
        <inertia>
          <ixx>1e-5</ixx><iyy>1e-5</iyy><izz>1e-5</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='tool0_visual'>
        <geometry><sphere><radius>0.018</radius></sphere></geometry>
        <material><ambient>1 1 0 1</ambient><diffuse>1 1 0 1</diffuse></material>
      </visual>
      <collision name='tool0_collision'>
        <geometry><sphere><radius>0.018</radius></sphere></geometry>
      </collision>
    </link>
    <joint name='j_ee' type='fixed'>
      <parent>ur5_link6</parent>
      <child>tool0</child>
    </joint>

    <plugin filename='libgz_ros2_control-system.so'
            name='gz_ros2_control::GazeboSimROS2ControlPlugin'>
      <parameters>@UAV_GZ_SIM_PKG_SHARE@/arms/ur5/config/controllers.yaml</parameters>
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <controller_manager_node_name>controller_manager</controller_manager_node_name>
      <ros>
        <namespace>@UAV_GZ_SIM_NAMESPACE@</namespace>
      </ros>
    </plugin>

  </model>
</sdf>
