<?xml version="1.0"?>
<!--
  Scaffold URDF/Xacro for the openmanip_x arm: cylinder chain with the upstream
  arm's joint names. Pairs with models/x500_with_openmanip_x/model.sdf so
  ros2_control sees the same kinematics in Gazebo.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="openmanip_x">

  <xacro:macro name="scaffold_link" params="name color_r color_g color_b">
    <link name="${name}">
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0.0500" rpy="0 0 0"/>
        <inertia ixx="8.693333e-05" iyy="8.693333e-05" izz="7.200000e-06"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0.0500" rpy="0 0 0"/>
        <geometry><cylinder radius="0.012" length="0.1"/></geometry>
        <material name="${name}_mat"><color rgba="${color_r} ${color_g} ${color_b} 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.0500" rpy="0 0 0"/>
        <geometry><cylinder radius="0.012" length="0.1"/></geometry>
      </collision>
    </link>
  </xacro:macro>

  <link name="base_link"/>

  <xacro:scaffold_link name="openmanip_x_link1" color_r="0.8" color_g="0.3" color_b="0.3"/>
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="openmanip_x_link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="2.0" velocity="3.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>
  <xacro:scaffold_link name="openmanip_x_link2" color_r="0.3" color_g="0.8" color_b="0.3"/>
  <joint name="joint2" type="revolute">
    <parent link="openmanip_x_link1"/>
    <child link="openmanip_x_link2"/>
    <origin xyz="0 0 0.1000" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="2.0" velocity="3.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>
  <xacro:scaffold_link name="openmanip_x_link3" color_r="0.3" color_g="0.3" color_b="0.8"/>
  <joint name="joint3" type="revolute">
    <parent link="openmanip_x_link2"/>
    <child link="openmanip_x_link3"/>
    <origin xyz="0 0 0.1000" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="2.0" velocity="3.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>
  <xacro:scaffold_link name="openmanip_x_link4" color_r="0.8" color_g="0.8" color_b="0.3"/>
  <joint name="joint4" type="revolute">
    <parent link="openmanip_x_link3"/>
    <child link="openmanip_x_link4"/>
    <origin xyz="0 0 0.1000" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="2.0" velocity="3.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <link name="end_effector_link">
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="1e-5" iyy="1e-5" izz="1e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.018"/></geometry>
      <material name="ee_mat"><color rgba="1 1 0 1"/></material>
    </visual>
    <collision><geometry><sphere radius="0.018"/></geometry></collision>
  </link>
  <joint name="j_ee" type="fixed">
    <parent link="openmanip_x_link4"/>
    <child link="end_effector_link"/>
    <origin xyz="0 0 0.1100" rpy="0 0 0"/>
  </joint>

  <xacro:arg name="sim_mode" default="gz"/>
  <ros2_control name="openmanip_x_hw" type="system">
    <hardware>
      <xacro:if value="${'$(arg sim_mode)' == 'gz'}">
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </xacro:if>
      <xacro:unless value="${'$(arg sim_mode)' == 'gz'}">
        <plugin>mock_components/GenericSystem</plugin>
      </xacro:unless>
    </hardware>
    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>